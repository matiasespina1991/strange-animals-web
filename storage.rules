rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /media/public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /media/public/webamp-skins/{skinId}/{version}/{fileName} {
      allow read: if true;
      allow write: if request.resource != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
